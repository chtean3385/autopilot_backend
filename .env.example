# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/hotel_leads_db
NODE_ENV=development
PORT=5000

# Backend URL for links (unsubscribe, etc.) — MUST be set in production
BACKEND_URL=http://localhost:5000

# WABA (Your WhatsApp Business API - Meta Cloud API)
WABA_PHONE_ID=your_phone_id_here
WABA_BUSINESS_ACCOUNT_ID=your_business_account_id
WABA_API_TOKEN=your_api_token_here
WABA_API_VERSION=v18.0

# Google Lead Search (Optional - Serper.dev)
SERPER_API_KEY=your_serper_key

# Email verification (mails.so)
VERIFIER_API_KEY=your_mails_so_api_key

# Email sending (Brevo)
BREVO_API_KEY=your_brevo_api_key

# Brevo webhook auth — set the same token in the Brevo webhook URL: /webhooks/brevo?token=...
BREVO_WEBHOOK_TOKEN=pick_a_random_secret

# Owner settings for email replies
OWNER_WEBSITE_URL=https://your-website.com
OWNER_NOTIFY_EMAIL=you@example.com
