{
  "name": "hotel-outreach-backend",
  "version": "1.0.1",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:setup": "psql -U postgres -d hotel_leads_db -f database/schema.sql",
    "db:reset": "psql -U postgres -d hotel_leads_db -c \"DROP SCHEMA public CASCADE; CREATE SCHEMA public;\" && npm run db:setup",
    "db:seed": "node database/seed.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.107.0",
    "axios": "^1.4.0",
    "cors": "^2.8.5",
    "csv-parse": "^7.0.1",
    "dotenv": "^16.0.3",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "fast-xml-parser": "^5.9.3",
    "multer": "^2.2.0",
    "node-schedule": "^2.1.1",
    "openai": "^6.45.0",
    "pg": "^8.8.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
